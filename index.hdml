                                    </div>
                                </div>
                                <span class="bg-brand-gold text-white text-[10px] font-bold px-2 py-0.5 rounded-full block w-fit mb-2">特典 3</span>
                                <h5 class="font-bold text-slate-900 text-xs md:text-sm mb-1">【PDF】最速1万円突破ロードマップ</h5>
                                <p class="text-[11px] text-slate-500 leading-relaxed">
                                    今日から何を、どの順番で動かせば最初の収入を手にできるかが明確にわかる、迷子防止マップ。
                                </p>
                            </div>

                        </div>
                    </div>

                </div>
            </div>
        </div>
    </section>

    <!-- 5. 【Narrowing down：絞り込み】 -->
    <section class="py-12 px-4 bg-orange-50/60 text-slate-800 text-center relative overflow-hidden border-y border-orange-100">
        <!-- AIファイバー線 -->
        <div class="absolute top-0 left-0 right-0 cyber-line"></div>
        
        <div class="max-w-xl mx-auto">
            <span class="block text-brand-orange font-extrabold text-sm tracking-wider uppercase mb-2">まもなく終了します！</span>
            <h2 class="font-serif text-2xl md:text-3xl font-black text-brand-navy mb-6 leading-snug">
                マンツーマンの丁寧なサポートを<br class="hidden sm:inline">
                維持するため、<span class="text-brand-orange text-3xl">【先着30名様】</span>限定です
            </h2>
            <p class="text-xs md:text-sm text-slate-600 leading-relaxed mb-8">
                大変ありがたいことに、現在お申し込みが殺到しております。お一人おひとりのお手元を丁寧に見守るサポート品質を維持するため、大変恐縮ですが人数に達し次第、予告なく通常価格（50,000円）に戻ります。あらかじめご了承ください。
            </p>

            <!-- カウントダウンタイマー (白地にシアンとオレンジのデジタル枠) -->
            <div class="bg-white p-5 rounded-2xl border border-cyan-200 shadow-cyber-glow inline-block w-full max-w-sm">
                <p class="text-xs text-slate-500 font-bold mb-3"><i class="fa-solid fa-clock mr-1 text-brand-cyan animate-pulse"></i> 特別割引キャンペーン終了まであと</p>
                <div class="flex justify-center space-x-3 text-slate-900">
                    <div class="bg-slate-50 p-3.5 rounded-xl min-w-[75px] shadow-sm border border-slate-100">
                        <span id="hours" class="block font-black text-2xl text-brand-cyan">23</span>
                        <span class="text-[9px] text-slate-500 block font-bold mt-1">時間</span>
                    </div>
                    <div class="bg-slate-50 p-3.5 rounded-xl min-w-[75px] shadow-sm border border-slate-100">
                        <span id="minutes" class="block font-black text-2xl text-brand-orange">59</span>
                        <span class="text-[9px] text-slate-500 block font-bold mt-1">分</span>
                    </div>
                    <div class="bg-slate-50 p-3.5 rounded-xl min-w-[75px] shadow-sm border border-slate-100">
                        <span id="seconds" class="block font-black text-2xl text-brand-cyan">59</span>
                        <span class="text-[9px] text-slate-500 block font-bold mt-1">秒</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- 6. 【Action：行動（CTA）】 -->
    <section id="cta-form" class="py-16 px-4 bg-white relative">
        <div class="max-w-xl mx-auto">
            <h2 class="font-serif text-2xl md:text-3xl font-black text-center text-brand-navy mb-2 leading-snug">
                まずはお気軽に無料の個別相談から
            </h2>
            <p class="text-center text-xs md:text-sm text-slate-500 mb-8 leading-relaxed">
                どのような不安でも結構です。下記のフォームに必要事項をご記入の上、送信してください。
            </p>

            <!-- 申し込みフォーム (シアンの柔らかいシャドウを持つクリーンなライトグレー背景) -->
            <form id="consultation-form" onsubmit="handleFormSubmit(event)" class="bg-slate-50/80 p-6 md:p-8 rounded-2xl border border-slate-200 shadow-cyber-glow space-y-6">
                <!-- お名前 -->
                <div>
                    <label for="name" class="block text-xs md:text-sm font-black text-slate-800 mb-2">
                        お名前（フルネーム） <span class="bg-red-500 text-white text-[9px] px-2 py-0.5 rounded font-normal ml-2">必須</span>
                    </label>
                    <input type="text" id="name" required placeholder="例：山田 太郎" class="w-full px-4 py-3 rounded-lg border border-slate-300 focus:outline-none focus:ring-2 focus:ring-brand-cyan text-slate-800 text-sm bg-white">
                </div>

                <!-- メールアドレス -->
                <div>
                    <label for="email" class="block text-xs md:text-sm font-black text-slate-800 mb-2">
                        メールアドレス <span class="bg-red-500 text-white text-[9px] px-2 py-0.5 rounded font-normal ml-2">必須</span>
                    </label>
                    <input type="email" id="email" required placeholder="例：yamada@example.com" class="w-full px-4 py-3 rounded-lg border border-slate-300 focus:outline-none focus:ring-2 focus:ring-brand-cyan text-slate-800 text-sm bg-white">
                </div>

                <!-- 年代 -->
                <div>
                    <label for="age" class="block text-xs md:text-sm font-black text-slate-800 mb-2">
                        ご年代 <span class="bg-slate-500 text-white text-[9px] px-2 py-0.5 rounded font-normal ml-2">任意</span>
                    </label>
                    <select id="age" class="w-full px-4 py-3 rounded-lg border border-slate-300 focus:outline-none focus:ring-2 focus:ring-brand-cyan text-slate-800 text-sm bg-white">
                        <option value="">選択してください</option>
                        <option value="60-64">60歳〜64歳</option>
                        <option value="65-69" selected>65歳〜69歳（おすすめ）</option>
                        <option value="70+">70歳以上</option>
                        <option value="other">その他</option>
                    </select>
                </div>

                <!-- 決済方法の希望 -->
                <div>
                    <label class="block text-xs md:text-sm font-black text-slate-800 mb-2">
                        ご希望の決済方法 <span class="bg-red-500 text-white text-[9px] px-2 py-0.5 rounded font-normal ml-2">必須</span>
                    </label>
                    <div class="grid grid-cols-2 gap-4">
                        <label class="flex items-center space-x-2 border p-3 rounded-lg bg-white cursor-pointer hover:border-brand-orange transition-all">
                            <input type="radio" name="payment" value="credit" checked class="text-brand-orange focus:ring-brand-orange">
                            <span class="text-xs md:text-sm font-bold text-slate-700">クレジットカード</span>
                        </label>
                        <label class="flex items-center space-x-2 border p-3 rounded-lg bg-white cursor-pointer hover:border-brand-cyan transition-all">
                            <input type="radio" name="payment" value="bank" class="text-brand-cyan focus:ring-brand-cyan">
                            <span class="text-xs md:text-sm font-bold text-slate-700">銀行振込</span>
                        </label>
                    </div>
                </div>

                <!-- プライバシーポリシー同意 -->
                <div class="flex items-start space-x-2">
                    <input type="checkbox" id="agree" required class="mt-1 text-brand-cyan focus:ring-brand-cyan rounded">
                    <label for="agree" class="text-[11px] text-slate-600">
                        個人情報の取り扱いおよび<span class="underline text-brand-cyan cursor-pointer">利用規約</span>に同意します。
                    </label>
                </div>

                <!-- CTA送信ボタン -->
                <button type="submit" class="w-full bg-brand-orange hover:bg-brand-orangeHover text-white font-black text-lg md:text-xl py-4.5 rounded-xl shadow-orange-glow transition-all border-b-4 border-orange-800 flex items-center justify-center space-x-2">
                    <span>申し込んで特典を受け取る</span>
                    <i class="fa-solid fa-chevron-right"></i>
                </button>
            </form>

            <!-- メッセージボックス (完了時表示) -->
            <div id="success-box" class="hidden mt-6 p-6 bg-emerald-50 border border-emerald-200 text-emerald-800 rounded-2xl shadow-premium text-center">
                <i class="fa-solid fa-circle-check text-3xl text-emerald-500 mb-2"></i>
                <h3 class="font-bold text-lg mb-1">お申し込みを受け付けました！</h3>
                <p class="text-sm">ご登録いただいたメールアドレス宛に、24時間以内に専門の担当相談員よりご連絡を差し上げます。また、お約束の「3大特典PDFマニュアル」もメールに添付してお送りしますので、ご確認ください。</p>
            </div>
        </div>
    </section>

    <!-- 講師・添削アドバイザー紹介 -->
    <section class="py-16 px-4 bg-slate-50 border-t border-slate-200/60 relative">
        <div class="max-w-2xl mx-auto text-center">
            <span class="text-xs bg-brand-accentBlue text-white px-3 py-1 rounded-full font-bold">私たちがサポートします</span>
            <h2 class="font-serif text-2xl md:text-3xl font-black text-brand-navy mt-3 mb-8">
                講師・アドバイザー紹介
            </h2>

            <!-- アップロードされたAIと調和する、親近感を持たせつつインテリジェンスを感じるプロフィールフレーム -->
            <div class="bg-white p-6 md:p-8 rounded-3xl shadow-premium border border-slate-200 flex flex-col items-center relative overflow-hidden">
                <div class="absolute -top-12 -left-12 w-24 h-24 bg-brand-cyan/10 rounded-full blur-xl"></div>
                
                <div class="w-24 h-24 rounded-full overflow-hidden mb-4 border-4 border-brand-cyan bg-slate-100 flex items-center justify-center shadow-md">
                    <!-- 講師の知性を象徴するSVGポートレートイメージ -->
                    <svg viewBox="0 0 100 100" class="w-16 h-16 text-brand-navy">
                        <circle cx="50" cy="35" r="18" fill="none" stroke="currentColor" stroke-width="4" />
                        <path d="M25 80 C 25 62, 75 62, 75 80" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" />
                        <!-- 知性を示すシアンの眼鏡フレーム -->
                        <path d="M40 35 L 48 35 M 52 35 L 60 35" stroke="#00b4d8" stroke-width="3" stroke-linecap="round" />
                    </svg>
                </div>
                <h3 class="font-bold text-lg text-slate-900 mb-1">高橋 誠 (たかはし まこと)</h3>
                <span class="text-xs text-brand-cyan font-bold mb-4">シニアAI副業専門アドバイザー</span>
                <p class="text-xs md:text-sm text-slate-600 leading-relaxed text-left">
                    「かつては新しいデジタル機器に苦労した経験から、徹底した『シニア専門の目線』で、あのアップロード画像にあるような最先端AIを誰でもお茶の子さいさいで使いこなせる指導法を開発しました。お孫さんとのスマートフォンのやり取りのように、やさしくお教えするのがモットーです。」
                </p>
            </div>
        </div>
    </section>

    <!-- よくある質問 Section -->
    <section class="py-16 px-4 bg-white">
        <div class="max-w-2xl mx-auto">
            <h2 class="font-serif text-2xl md:text-3xl font-black text-center text-brand-navy mb-8 leading-snug">
                よくあるご質問（Q&A）
            </h2>

            <div class="space-y-4">
                <!-- 質問1 -->
                <div class="bg-slate-50/50 rounded-xl shadow-sm border border-slate-200 overflow-hidden">
                    <button onclick="toggleFaq(1)" class="w-full text-left p-5 font-bold text-slate-800 flex justify-between items-center hover:bg-slate-100 transition-all">
                        <span class="text-sm md:text-base pr-3 text-brand-navy">Q1. 本当に1日30分だけで効果が期待できますか？</span>
                        <i id="faq-icon-1" class="fa-solid fa-chevron-down text-slate-400"></i>
                    </button>
                    <div id="faq-answer-1" class="hidden p-5 border-t border-slate-200 text-slate-600 text-xs md:text-sm bg-white leading-relaxed">
                        はい、十分に可能なお時間です。忙しい日々のちょっとした合間にできるよう、ポイントを極限まで絞り、直感的で分かりやすい手順のみをマニュアル化して添削を行います。
                    </div>
                </div>

                <!-- 質問2 -->
                <div class="bg-slate-50/50 rounded-xl shadow-sm border border-slate-200 overflow-hidden">
                    <button onclick="toggleFaq(2)" class="w-full text-left p-5 font-bold text-slate-800 flex justify-between items-center hover:bg-slate-100 transition-all">
                        <span class="text-sm md:text-base pr-3 text-brand-navy">Q2. パソコンのタイピングが遅くても問題ないですか？</span>
                        <i id="faq-icon-2" class="fa-solid fa-chevron-down text-slate-400"></i>
                    </button>
                    <div id="faq-answer-2" class="hidden p-5 border-t border-slate-200 text-slate-600 text-xs md:text-sm bg-white leading-relaxed">
                        まったく問題ございません。AIへの指示は、普通に手紙やLINEを送るのと同じ平易な日本語で行います。また、コピーしてすぐに貼り付けられる便利な「テンプレート指示文」を多数お渡ししますので、文字入力の手間は最小限で済みます。
                    </div>
                </div>

                <!-- 質問3 -->
                <div class="bg-slate-50/50 rounded-xl shadow-sm border border-slate-200 overflow-hidden">
                    <button onclick="toggleFaq(3)" class="w-full text-left p-5 font-bold text-slate-800 flex justify-between items-center hover:bg-slate-100 transition-all">
                        <span class="text-sm md:text-base pr-3 text-brand-navy">Q3. 途中で操作方法が分からなくなったらどうすればいいですか？</span>
                        <i id="faq-icon-3" class="fa-solid fa-chevron-down text-slate-400"></i>
                    </button>
                    <div id="faq-answer-3" class="hidden p-5 border-t border-slate-200 text-slate-600 text-xs md:text-sm bg-white leading-relaxed">
                        24時間、いつでも丁寧に対応できる問い合わせ質問窓口を完備しております。専門のカウンセラーが、つまづいたポイントを優しく分かりやすい言葉で個別にサポートいたしますので、挫折することなく進めていただけます。
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- フッター -->
    <footer class="bg-slate-50 text-slate-500 py-10 px-4 text-xs text-center border-t border-slate-200">
        <div class="max-w-4xl mx-auto space-y-4">
            <div class="flex flex-wrap justify-center gap-6 text-slate-600 font-medium mb-4">
                <a href="#" class="hover:underline hover:text-brand-orange">特定商取引法に基づく表記</a>
                <a href="#" class="hover:underline hover:text-brand-orange">プライバシーポリシー</a>
                <a href="#" class="hover:underline hover:text-brand-orange">利用規約</a>
                <a href="#" class="hover:underline hover:text-brand-orange">運営組織情報</a>
            </div>
            <p>※本プログラムの効果には個人差があり、特定の成果や収入を確定的に保証するものではございません。</p>
            <p>&copy; 2026 AIツール副業個別相談事務局 All Rights Reserved.</p>
        </div>
    </footer>

    <!-- JavaScriptの制御 -->
    <script>
        // ページロード時の初期設定
        window.onload = function() {
            startCountdown();
        };

        // 1. カウントダウンタイマーの実装
        function startCountdown() {
            let hours = 23;
            let minutes = 59;
            let seconds = 59;

            const hoursEl = document.getElementById('hours');
            const minutesEl = document.getElementById('minutes');
            const secondsEl = document.getElementById('seconds');

            const timer = setInterval(() => {
                seconds--;
                if (seconds < 0) {
                    seconds = 59;
                    minutes--;
                    if (minutes < 0) {
                        minutes = 59;
                        hours--;
                        if (hours < 0) {
                            // デモ維持のためリピート
                            hours = 23;
                            minutes = 59;
                            seconds = 59;
                        }
                    }
                }

                // 表示の更新 (2桁表示にパディング)
                if(hoursEl) hoursEl.textContent = String(hours).padStart(2, '0');
                if(minutesEl) minutesEl.textContent = String(minutes).padStart(2, '0');
                if(secondsEl) secondsEl.textContent = String(seconds).padStart(2, '0');
            }, 1000);
        }

        // 2. よくある質問のアコーディオン制御
        function toggleFaq(id) {
            const answer = document.getElementById(`faq-answer-${id}`);
            const icon = document.getElementById(`faq-icon-${id}`);

            if (answer.classList.contains('hidden')) {
                answer.classList.remove('hidden');
                icon.classList.remove('fa-chevron-down');
                icon.classList.add('fa-chevron-up');
            } else {
                answer.classList.add('hidden');
                icon.classList.remove('fa-chevron-up');
                icon.classList.add('fa-chevron-down');
            }
        }

        // 3. お申し込みフォームの処理 (疑似送信処理)
        function handleFormSubmit(event) {
            event.preventDefault(); // デフォルトの送信挙動を防止

            const form = document.getElementById('consultation-form');
            const successBox = document.getElementById('success-box');

            // フォームを非表示にし、成功画面を表示
            form.classList.add('hidden');
            successBox.classList.remove('hidden');

            // 成功メッセージまでスムーズスクロール
            successBox.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
    </script>
</body>
</html>

